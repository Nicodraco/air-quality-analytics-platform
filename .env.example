# OpenAQ API Key (gratis en https://explore.openaq.org/register)
OPENAQ_API_KEY=your_openaq_api_key_here

# AEMET API Key (gratis en https://opendata.aemet.es)
AEMET_API_KEY=your_aemet_api_key_here

# LLM API Key (OpenAI compatible)
LLM_API_KEY=your_llm_api_key_here
LLM_API_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Open-Meteo no necesita API key - es gratuito y sin autenticación
