# AEMET OpenData (obligatorio)
API_KEY_AEMET=your_aemet_api_key_here
AEMET_BASE_URL=https://opendata.aemet.es/opendata/api

# MITECO / datos abiertos
URL_BUSQUEDA_MITECO=https://miteco.gob.es
URL_DATASTORE_MITECO=https://datos.gob.es/apidata/catalog/dataset

# MinIO (Bronze Layer)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=ambiental-lake
MINIO_SECURE=false
USE_LOCAL_BRONZE_FALLBACK=true

# PostgreSQL (Gold Layer)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ambiental_dw
POSTGRES_USER=ambiental
POSTGRES_PASSWORD=ambiental123

# LLM (resúmenes diarios)
# ollama | openai | narrativo (generador automático sin API)
LLM_PROVIDER=narrativo
LLM_API_URL=http://localhost:11434
LLM_MODEL=llama3
LLM_API_KEY=

# Pipeline
PIPELINE_INTERVAL_MINUTES=60
INGESTION_LOOKBACK_DAYS=90
FORECAST_DAYS=7
